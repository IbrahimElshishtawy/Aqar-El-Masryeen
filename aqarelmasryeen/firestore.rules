rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isActivePartner() {
      return isSignedIn()
        && currentUserExists()
        && currentUserDoc().data.role == 'partner'
        && currentUserDoc().data.isActive == true;
    }

    function currentWorkspaceId() {
      return currentUserDoc().data.workspaceId;
    }

    function hasWorkspace() {
      return isActivePartner()
        && currentWorkspaceId() is string
        && currentWorkspaceId() != '';
    }

    function matchesWorkspace(data) {
      return hasWorkspace()
        && data.workspaceId is string
        && data.workspaceId != ''
        && data.workspaceId == currentWorkspaceId();
    }

    function creatorInWorkspace(data) {
      return hasWorkspace()
        && data.createdBy is string
        && data.createdBy != ''
        && exists(/databases/$(database)/documents/users/$(data.createdBy))
        && get(/databases/$(database)/documents/users/$(data.createdBy)).data.workspaceId == currentWorkspaceId();
    }

    function matchesWorkspaceOrCreator(data) {
      return matchesWorkspace(data) || creatorInWorkspace(data);
    }

    function immutableUserCore(userId) {
      return request.resource.data.uid == userId
        && request.resource.data.role == resource.data.role
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function validUserProfile(userId) {
      return request.resource.data.uid == userId
        && request.resource.data.role == 'partner'
        && request.resource.data.fullName is string
        && request.resource.data.email is string
        && request.resource.data.biometricEnabled is bool
        && request.resource.data.appLockEnabled is bool
        && (request.resource.data.trustedDeviceEnabled == null
          || request.resource.data.trustedDeviceEnabled is bool)
        && request.resource.data.isActive is bool
        && request.resource.data.inactivityTimeoutSeconds is int
        && request.resource.data.inactivityTimeoutSeconds >= 30
        && request.resource.data.inactivityTimeoutSeconds <= 300;
    }

    function hasValidRequestedWorkspace() {
      return request.resource.data.workspaceId is string
        && request.resource.data.workspaceId != '';
    }

    function canBootstrapOwnWorkspace(userId) {
      return isOwner(userId)
        && (!('workspaceId' in resource.data)
          || !(resource.data.workspaceId is string)
          || resource.data.workspaceId == '')
        && hasValidRequestedWorkspace();
    }

    match /users/{userId} {
      allow create: if ((isOwner(userId) && hasValidRequestedWorkspace())
        || (isActivePartner() && matchesWorkspace(request.resource.data)))
        && validUserProfile(userId)
        && request.resource.data.isActive == true;

      allow read: if isOwner(userId)
        || (hasWorkspace() && matchesWorkspace(resource.data))
        || (isActivePartner() && resource.data.createdBy == request.auth.uid);

      allow update: if (isOwner(userId) || (hasWorkspace() && matchesWorkspace(resource.data)))
        && immutableUserCore(userId)
        && validUserProfile(userId)
        && (matchesWorkspace(request.resource.data) || canBootstrapOwnWorkspace(userId));

      allow delete: if false;
    }

    match /user_email_lookup/{email} {
      allow read: if isActivePartner();
      allow create, update: if isSignedIn()
        && request.resource.data.uid is string
        && request.resource.data.email == email
        && (request.auth.uid == request.resource.data.uid || isActivePartner());
      allow delete: if isSignedIn()
        && (request.auth.uid == resource.data.uid || isActivePartner());
    }

    match /notifications/{notificationId} {
      allow create: if hasWorkspace() && matchesWorkspace(request.resource.data);
      allow read, update: if hasWorkspace()
        && resource.data.userId == request.auth.uid
        && matchesWorkspace(resource.data);
      allow delete: if false;
    }

    match /activity_logs/{logId} {
      allow create: if hasWorkspace() && matchesWorkspace(request.resource.data);
      allow read: if hasWorkspace() && matchesWorkspace(resource.data);
      allow update, delete: if false;
    }

    match /settings/{settingId} {
      allow read, write: if isActivePartner();
    }

    match /{collection}/{documentId} {
      allow read: if hasWorkspace()
        && collection in [
          'partners',
          'properties',
          'expenses',
          'unit_expenses',
          'material_expenses',
          'supplier_payments',
          'units',
          'installment_plans',
          'installments',
          'payments',
          'partner_ledgers'
        ]
        && matchesWorkspaceOrCreator(resource.data);
      allow create, update: if hasWorkspace()
        && collection in [
          'partners',
          'properties',
          'expenses',
          'unit_expenses',
          'material_expenses',
          'supplier_payments',
          'units',
          'installment_plans',
          'installments',
          'payments',
          'partner_ledgers'
        ]
        && matchesWorkspaceOrCreator(request.resource.data);
      allow delete: if hasWorkspace()
        && collection in [
          'partners',
          'properties',
          'expenses',
          'unit_expenses',
          'material_expenses',
          'supplier_payments',
          'units',
          'installment_plans',
          'installments',
          'payments',
          'partner_ledgers'
        ]
        && matchesWorkspaceOrCreator(resource.data);
    }
  }
}
